# .env.example - 環境変数のサンプルファイル
#
# このファイルをコピーして .env を作成し、各値を本番用に変更してください。
#   cp .env.example .env
#
# .env はコミットしてはいけません（.gitignore に記載済み）。

# ---------------------------------------------------------------
# 署名付きURL・セッション管理用シークレットキー
# Nginx の secure_link_md5 と FastAPI セッションで共有する。
# 本番環境では十分にランダムな値を設定すること。
# 例: python3 -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------
SECRET_KEY=changeme_replace_in_production

# ---------------------------------------------------------------
# 管理者パスワード（/api/login で使用）
# 本番環境では必ず変更すること。
# ---------------------------------------------------------------
ADMIN_PASSWORD=admin

# ---------------------------------------------------------------
# PostgreSQL 接続情報
# docker-compose の db サービスと一致させること。
# ---------------------------------------------------------------
POSTGRES_DB=minitube
POSTGRES_USER=minitube
POSTGRES_PASSWORD=changeme_replace_in_production

# ---------------------------------------------------------------
# MinIO 接続情報
# HLS ファイル（playlist.m3u8 + segment*.ts）の永続保存先。
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY は MinIO の root 認証情報。
# MINIO_ENDPOINT は FastAPI/Worker から MinIO API へのアクセス先。
#   （compose 内部ネットワーク: http://minio:9000）
# MINIO_BUCKET は HLS ファイルを保存するバケット名。
# 本番環境では強固な値に変更すること。
# ---------------------------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio_secret
MINIO_BUCKET=minitube
